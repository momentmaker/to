# --- Telegram (required) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
MODE=webhook                        # webhook|polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# --- LLM providers (required from Stage 2) ---
# At least one of ANTHROPIC_API_KEY / OPENAI_API_KEY is required.
# OPENAI_API_KEY is also required for Whisper transcription.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Per-purpose provider routing: anthropic|openai
LLM_PROVIDER_INGEST=anthropic
LLM_PROVIDER_DAILY=anthropic
LLM_PROVIDER_WHY=anthropic
LLM_PROVIDER_DIGEST=anthropic
LLM_PROVIDER_ORACLE=anthropic
LLM_PROVIDER_TWEET=openai
LLM_PROVIDER_VISION=anthropic

CLAUDE_MODEL_INGEST=claude-sonnet-4-6
CLAUDE_MODEL_DIGEST=claude-opus-4-7
CLAUDE_MODEL_CHEAP=claude-haiku-4-5-20251001
OPENAI_MODEL_INGEST=gpt-4.1-mini
OPENAI_MODEL_DIGEST=gpt-4.1
OPENAI_MODEL_CHEAP=gpt-4.1-nano

# --- Storage ---
SQLITE_PATH=/data/to.db
DOB=                                # ISO date YYYY-MM-DD; drives fz.ax week index
TIMEZONE=Asia/Tokyo
WEEK_START=mon                      # mon|sun

# --- GitHub sync (required from Stage 3) ---
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main

# --- Optional ingestion (Stage 2) ---
ZYTE_API_KEY=
EXA_API_KEY=

# --- Scheduling ---
DAILY_PROMPT_LOCAL_TIME=21:30
# The weekly digest cron is opt-IN because it's the most expensive LLM
# operation in the bot (~$0.30–$1 per Opus run). Leave false to run the
# digest yourself locally via Claude Code against the captures repo, or
# set true to let the bot fire it automatically every Saturday night.
# Either way, /export still works on demand.
WEEKLY_DIGEST_ENABLED=false
WEEKLY_DIGEST_DOW=sat
WEEKLY_DIGEST_LOCAL_TIME=22:00
WHY_WINDOW_MINUTES=10

# --- Optional X posting (Stage 7) ---
X_DAILY_ENABLED=false
X_WEEKLY_ENABLED=false
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# --- Optional alerting ---
DHYAMA_BOT_TOKEN=
DHYAMA_CHAT_ID=

# --- Budget ---
LLM_MONTHLY_USD_CAP=30
LOG_LEVEL=INFO
